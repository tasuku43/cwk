{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/check.sh\"",
            "timeout": 180,
            "statusMessage": "Running the canonical fast repository gate"
          }
        ]
      }
    ]
  }
}
